# Server environment variables (server/.env — do not commit)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=
UAZAPI_BASE_URL=https://free.uazapi.com
UAZAPI_ADMIN_TOKEN=
PUBLIC_WEBHOOK_BASE_URL=https://your-tunnel.example.com
WHATSAPP_LOG_LEVEL=info
PORT=3000

# Client build-time variables (client/.env.local — do not commit)
# These must be available during `bun --bun run build` in Docker stage 1
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=
VITE_API_BASE_URL=
